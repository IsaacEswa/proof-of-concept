<div class="quiz-component">

    <!-- SCORE SCREEN -->
    {% if screen == 'score' %}
    <div class="score-container">
        <svg aria-hidden="true" width="150" xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 640 640"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
            <path
                d="M530.8 134.1C545.1 144.5 548.3 164.5 537.9 178.8L281.9 530.8C276.4 538.4 267.9 543.1 258.5 543.9C249.1 544.7 240 541.2 233.4 534.6L105.4 406.6C92.9 394.1 92.9 373.8 105.4 361.3C117.9 348.8 138.2 348.8 150.7 361.3L252.2 462.8L486.2 141.1C496.6 126.8 516.6 123.6 530.9 134z" />
        </svg>
        <h3 class="score-result">Jouw score: </h3>
        <p>Goed gedaan, je bent klaar met de quiz! Je kan het altijd nog een keer proberen.</p>
        <a class="primary-button quiz-btn" href="/">
            Herstart
        </a>
    </div>

    <!-- RESULT SCREEN -->
    {% elsif screen == 'result' %}
    <div class="quiz-feedback">
        <small class="question-progress">
            Vraag {{ step | plus: 1 }}/{{ sections.size }}
        </small>
        <h3 class="question-title">{{ question.question }}</h3>
        <div class="selected-answer {% if correct == 'true' %}is-correct{% else %}is-wrong{% endif %}">
            <p>{{ selectedOption.key }}. {{ selectedOption.answer }}</p>
            {% if correct == 'true' %}
            <span aria-hidden="true">✔</span>
            {% else %}
            <span aria-hidden="true">✖</span>
            {% endif %}
        </div>

        <div class="question-explanation">
            {% if correct == 'true' %}
            <p>{{ question.explanation_correct }}</p>
            {% else %}
            <p>{{ question.explanation_wrong }}</p>
            {% endif %}
            <a href="">Lees meer</a>
        </div>

        {% assign last = sections.size | minus: 1 %}
        <a class="primary-button quiz-btn next-question"
            href="{% if step >= last %}/?screen=score{% else %}/?step={{ step | plus: 1 }}{% endif %}">
            Volgende
        </a>
    </div>

    {% else %}

    {% for section in sections %}
    <article class="single-quiz-question {% if step != forloop.index0 %}is-hidden{% endif %}">
        <form class="question-answer-form" action="/quiz/answer" method="post">
            <input type="hidden" name="questionId" value="{{ section.questions[0].id }}">
            <input type="hidden" name="step" value="{{ forloop.index0 }}">

            <fieldset class="quiz-options">
                <legend>
                    <small class="question-progress">
                        Vraag {{ forloop.index }}/{{ sections.size }}
                    </small>

                    <h3 class="question-title">{{ section.questions[0].question }}</h3>
                </legend>

                {% assign question = section.questions[0] %}
                {% for option in question.options %}
                <label class="quiz-option">
                    <input type="radio" name="answerKey" value="{{ option.key }}" required>
                    {{ option.key }}. {{ option.answer }}
                </label>
                {% endfor %}
            </fieldset>

            <button class="primary-button quiz-btn" type="submit">
                Controleren
            </button>
        </form>
    </article>
    {% endfor %}
    {% endif %}
</div>