{% render 'partials/head.liquid' %}

<section class="timeline" hidden>
    {% comment %} <h2 class="section-title">Timeline van de Grote Elektriseermachine</h2> {% endcomment %}
    {% render 'partials/timeline-component.liquid', timelineItems: timelineItems %}

</section>


<section class="quiz">
    {% for quizQuestion in quizQuestions %}
    <card>
        <button class="back-btn">Terug</button>
        <span class="question-progress">Vraag 1/10</span>
        <h2>{{ quizQuestion.question }}</h2>
        <fieldset>
            {% for option in quizQuestion.options %}
            <label>
                <input type="radio" name="question-{{ quizQuestion.id }}" value="{{ option.key }}">
                {{ option.key }}. {{ option.answer }}
            </label>
            {% endfor %}
        </fieldset>

        <p>Korte uitleg</p>
        <button class="next-btn">Volgende</button>

    </card>
    {% endfor %}


</section>

{% render 'partials/foot.liquid' %}

{% comment %}
{% for block in timelineItem.content_blocks %}
<p>{{ block.text }}</p>
{% endfor %} {% endcomment %}